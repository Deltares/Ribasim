{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "julia",
            "request": "launch",
            "name": "debug Ribasim",
            "program": "debug/debug.jl",
            "stopOnEntry": false,
            "cwd": "${workspaceFolder}",
            "juliaEnv": "${command:activeJuliaEnvironment}"
        },
        {
            "type": "julia",
            "request": "launch",
            "name": "Julia: current file",
            "program": "${file}",
            "stopOnEntry": false,
            "cwd": "${workspaceFolder}",
            "juliaEnv": "${command:activeJuliaEnvironment}"
        },
        {
            "name": "Ribasim QGIS: Attach to QGIS",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "127.0.0.1",
                "port": 5678
            },
            "justMyCode": false
        },
        {
            "name": "Run Python debugger",
            "type": "debugpy",
            "request": "launch",
            "justMyCode": false,
            "console": "integratedTerminal",
            "purpose": ["debug-test"]
        }
    ]
}
